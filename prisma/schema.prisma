// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["vendor_delivery"]
}

// ─── VENDORS ──────────────────────────────────────────────────────────────────

model Vendor {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName       String    @map("business_name") @db.VarChar(255)
  ownerName          String    @map("owner_name") @db.VarChar(255)
  phone              String    @unique @db.VarChar(20)
  email              String?   @unique @db.VarChar(255)
  businessAddress    String    @map("business_address")
  latitude           Decimal?  @db.Decimal(10, 7)
  longitude          Decimal?  @db.Decimal(10, 7)
  deliveryRadius     Decimal?  @map("delivery_radius") @db.Decimal(6, 2)
  storeDescription   String?   @map("store_description")
  businessCategory   String?   @map("business_category") @db.VarChar(100)
  logoUrl            String?   @map("logo_url")
  bannerUrl          String?   @map("banner_url")
  profilePicUrl      String?   @map("profile_pic_url")
  operatingHours     Json?     @map("operating_hours")
  accountStatus      String    @default("kyc_submitted") @map("account_status") @db.VarChar(50)
  onlineStatus       String?   @default("offline") @map("online_status") @db.VarChar(30)
  stopNewOrdersSince DateTime? @map("stop_new_orders_since") @db.Timestamptz()
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  kycDocs            VendorKyc[]
  bankDetails        VendorBankDetails?
  complianceFlags    VendorComplianceFlag[]
  products           Product[]
  orderActions       VendorOrderAction[]
  earnings           VendorEarning[]
  productSubmissions ProductReviewSubmission[]

  @@map("vendors")
  @@schema("vendor_delivery")
}

// Vendor KYC document records
model VendorKyc {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId          String    @map("vendor_id") @db.Uuid
  govIdType         String?   @map("gov_id_type") @db.VarChar(50)
  govIdUrl          String?   @map("gov_id_url")
  businessProofType String?   @map("business_proof_type") @db.VarChar(50)
  businessProofUrl  String?   @map("business_proof_url")
  panUrl            String?   @map("pan_url")
  addressProofUrl   String?   @map("address_proof_url")
  submissionRound   Int       @default(1) @map("submission_round")
  submittedAt       DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_kyc")
  @@schema("vendor_delivery")
}

// Bank/payout details for vendors
model VendorBankDetails {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId      String    @unique @map("vendor_id") @db.Uuid
  accountHolder String    @map("account_holder") @db.VarChar(255)
  bankName      String    @map("bank_name") @db.VarChar(255)
  accountNumber String    @map("account_number") @db.VarChar(50)
  ifscCode      String    @map("ifsc_code") @db.VarChar(20)
  upiId         String?   @map("upi_id") @db.VarChar(100)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_bank_details")
  @@schema("vendor_delivery")
}

// Vendor compliance flags log
model VendorComplianceFlag {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String    @map("vendor_id") @db.Uuid
  flagType  String    @map("flag_type") @db.VarChar(100)
  orderId   String?   @map("order_id") @db.Uuid
  flaggedAt DateTime? @default(now()) @map("flagged_at") @db.Timestamptz()
  notes     String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_compliance_flags")
  @@schema("vendor_delivery")
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

// Product catalogue per vendor
model Product {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId     String    @map("vendor_id") @db.Uuid
  name         String    @db.VarChar(255)
  description  String?
  category     String?   @db.VarChar(100)
  productType  String?   @map("product_type") @db.VarChar(100)
  basePrice    Decimal   @map("base_price") @db.Decimal(10, 2)
  isRestricted Boolean?  @default(false) @map("is_restricted")
  isActive     Boolean?  @default(true) @map("is_active")
  reviewStatus String    @default("pending_review") @map("review_status") @db.VarChar(30)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  vendor      Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  addOns      ProductAddon[]
  submissions ProductReviewSubmission[]
  snapshots   ProductReviewSnapshot[]

  @@map("products")
  @@schema("vendor_delivery")
}

// Preloaded product templates for faster product creation
model ProductTemplate {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(255)
  category     String?   @db.VarChar(100)
  description  String?
  templateData Json?     @map("template_data")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz()

  @@map("product_templates")
  @@schema("vendor_delivery")
}

// Add-ons available per product
model ProductAddon {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String    @map("product_id") @db.Uuid
  name      String    @db.VarChar(255)
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_addons")
  @@schema("vendor_delivery")
}

// ─── ORDERS (vendor side view) ────────────────────────────────────────────────

// Vendor responses to incoming orders
model VendorOrderAction {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @map("order_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  action          String    @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason") @db.VarChar(100)
  rejectionNote   String?   @map("rejection_note")
  newStatus       String?   @map("new_status") @db.VarChar(50)
  actionedAt      DateTime? @default(now()) @map("actioned_at") @db.Timestamptz()

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_order_actions")
  @@schema("vendor_delivery")
}

// Vendor earnings per completed order
model VendorEarning {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId       String    @map("vendor_id") @db.Uuid
  orderId        String    @unique @map("order_id") @db.Uuid
  orderTotal     Decimal   @map("order_total") @db.Decimal(10, 2)
  commissionRate Decimal   @map("commission_rate") @db.Decimal(5, 2)
  commissionAmt  Decimal   @map("commission_amt") @db.Decimal(10, 2)
  vendorPayout   Decimal   @map("vendor_payout") @db.Decimal(10, 2)
  earnedAt       DateTime? @default(now()) @map("earned_at") @db.Timestamptz()

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_earnings")
  @@schema("vendor_delivery")
}

// ─── DELIVERY PARTNERS (RIDERS) ───────────────────────────────────────────────

model Rider {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName           String    @map("full_name") @db.VarChar(255)
  phone              String    @unique @db.VarChar(20)
  email              String?   @unique @db.VarChar(255)
  profilePicUrl      String?   @map("profile_pic_url")
  vehicleType        String?   @map("vehicle_type") @db.VarChar(50)
  vehicleNumber      String?   @map("vehicle_number") @db.VarChar(50)
  preferredZone      String?   @map("preferred_zone")
  currentLat         Decimal?  @map("current_lat") @db.Decimal(10, 7)
  currentLng         Decimal?  @map("current_lng") @db.Decimal(10, 7)
  accountStatus      String    @default("kyc_submitted") @map("account_status") @db.VarChar(50)
  onlineStatus       String?   @default("offline") @map("online_status") @db.VarChar(30)
  stopNewOrdersSince DateTime? @map("stop_new_orders_since") @db.Timestamptz()
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  kycDocs               RiderKyc[]
  bankDetails           RiderBankDetails?
  complianceFlags       RiderComplianceFlag[]
  pickupRequests        PickupRequest[]
  deliveryStatusUpdates DeliveryStatusUpdate[]
  earnings              RiderEarning[]

  @@map("riders")
  @@schema("vendor_delivery")
}

// Rider KYC documents
model RiderKyc {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riderId           String    @map("rider_id") @db.Uuid
  govIdType         String?   @map("gov_id_type") @db.VarChar(50)
  govIdUrl          String?   @map("gov_id_url")
  drivingLicenseUrl String?   @map("driving_license_url")
  vehicleRegUrl     String?   @map("vehicle_reg_url")
  submissionRound   Int       @default(1) @map("submission_round")
  submittedAt       DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@map("rider_kyc")
  @@schema("vendor_delivery")
}

// Bank/payout details for riders
model RiderBankDetails {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riderId       String    @unique @map("rider_id") @db.Uuid
  accountHolder String    @map("account_holder") @db.VarChar(255)
  bankName      String    @map("bank_name") @db.VarChar(255)
  accountNumber String    @map("account_number") @db.VarChar(50)
  ifscCode      String    @map("ifsc_code") @db.VarChar(20)
  upiId         String?   @map("upi_id") @db.VarChar(100)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@map("rider_bank_details")
  @@schema("vendor_delivery")
}

// Rider compliance flags
model RiderComplianceFlag {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riderId   String    @map("rider_id") @db.Uuid
  flagType  String    @map("flag_type") @db.VarChar(100)
  orderId   String?   @map("order_id") @db.Uuid
  flaggedAt DateTime? @default(now()) @map("flagged_at") @db.Timestamptz()
  notes     String?

  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@map("rider_compliance_flags")
  @@schema("vendor_delivery")
}

// Pickup request assignments per order
model PickupRequest {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  riderId     String    @map("rider_id") @db.Uuid
  status      String    @default("broadcast") @db.VarChar(30)
  respondedAt DateTime? @map("responded_at") @db.Timestamptz()
  assignedAt  DateTime? @default(now()) @map("assigned_at") @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("pickup_requests")
  @@schema("vendor_delivery")
}

// Delivery status updates pushed by rider for an order
model DeliveryStatusUpdate {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String    @map("order_id") @db.Uuid
  riderId   String    @map("rider_id") @db.Uuid
  status    String    @db.VarChar(50)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("delivery_status_updates")
  @@schema("vendor_delivery")
}

// Rider earnings per delivery
model RiderEarning {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  riderId     String    @map("rider_id") @db.Uuid
  orderId     String    @unique @map("order_id") @db.Uuid
  fixedFee    Decimal   @map("fixed_fee") @db.Decimal(10, 2)
  distanceFee Decimal   @default(0) @map("distance_fee") @db.Decimal(10, 2)
  totalPayout Decimal   @map("total_payout") @db.Decimal(10, 2)
  earnedAt    DateTime? @default(now()) @map("earned_at") @db.Timestamptz()

  rider Rider @relation(fields: [riderId], references: [id])

  @@map("rider_earnings")
  @@schema("vendor_delivery")
}

// ─── vendor_delivery schema additions ────────────────────────────────────────

// Tracks the review status of each product submission (or re-submission)
model ProductReviewSubmission {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  submissionRound Int       @default(1) @map("submission_round")
  status          String    @default("pending_review") @db.VarChar(30)
  submittedAt     DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor    Vendor                  @relation(fields: [vendorId], references: [id])
  snapshots ProductReviewSnapshot[]

  @@map("product_review_submissions")
  @@schema("vendor_delivery")
}

// Snapshot of product fields at the time of each submission
// Lets admin review exactly what was submitted, even if vendor edits later
model ProductReviewSnapshot {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId  String    @map("submission_id") @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  name          String    @db.VarChar(255)
  description   String?
  category      String?   @db.VarChar(100)
  productType   String?   @map("product_type") @db.VarChar(100)
  basePrice     Decimal   @map("base_price") @db.Decimal(10, 2)
  isRestricted  Boolean?  @default(false) @map("is_restricted")
  snapshotData  Json?     @map("snapshot_data")
  snapshottedAt DateTime? @default(now()) @map("snapshotted_at") @db.Timestamptz()

  submission ProductReviewSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  product    Product                 @relation(fields: [productId], references: [id])

  @@map("product_review_snapshots")
  @@schema("vendor_delivery")
}
