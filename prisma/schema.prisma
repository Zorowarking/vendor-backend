// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../server/node_modules/.prisma/client"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["vendor_delivery", "customer"]
}

// ─── SHARED MODELS (ALIGNED WITH CUSTOMER APP) ───────────────────────────────

model Customer {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId      String?    @unique @map("profile_id") @db.Uuid
  phone          String     @unique @db.VarChar(20)
  email          String?    @unique @db.VarChar(255)
  fullName       String?    @map("full_name") @db.VarChar(255)

  isGuest        Boolean    @default(false) @map("is_guest")
  sessionToken   String?    @map("session_token")
  guestExpiresAt DateTime?  @map("guest_expires_at") @db.Timestamptz(6)

  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  profile            Profile?   @relation(fields: [profileId], references: [id])
  address            Address?
  ageVerification    AgeVerification?
  cart               Cart?
  orders             Order[]
  feedbacks          Feedback[]
  supportRequests    SupportRequest[]
  analyticsEvents    AnalyticsEvent[]

  @@map("customers")
  @@schema("customer")
}

model Address {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId   String    @unique @map("customer_id") @db.Uuid

  addressLine1 String    @map("address_line1")
  addressLine2 String?   @map("address_line2")
  city         String    @db.VarChar(100)
  state        String    @db.VarChar(100)
  postalCode   String    @map("postal_code") @db.VarChar(20)
  landmark     String?
  latitude     Decimal?  @db.Decimal(10, 8)
  longitude    Decimal?  @db.Decimal(11, 8)
  addressType  String?   @map("address_type") @db.VarChar(50)

  contactName  String?   @map("contact_name") @db.VarChar(255)
  contactPhone String?   @map("contact_phone") @db.VarChar(50)

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
  @@schema("customer")
}

model Order {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId            String               @map("customer_id") @db.Uuid

  vendorId              String               @map("vendor_id") @db.Uuid
  riderId               String?              @map("rider_id") @db.Uuid

  addressSnapshot       Json                 @map("address_snapshot")
  deliveryPreference    String?              @map("delivery_preference") @db.VarChar(50)

  status                String               @default("payment_successful") @db.VarChar(50)

  subtotal              Decimal              @db.Decimal(10, 2)
  addonCharges          Decimal              @default(0) @map("addon_charges") @db.Decimal(10, 2)
  deliveryFee           Decimal              @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  totalAmount           Decimal              @map("total_amount") @db.Decimal(10, 2)

  paymentMethod         String?              @map("payment_method") @db.VarChar(50)
  paymentGatewayRef     String?              @map("payment_gateway_ref")

  ageVerifiedCheckbox   Boolean              @default(false) @map("age_verified_checkbox")
  isFlagged             Boolean              @default(false) @map("is_flagged")
  isFlaggedAdmin        Boolean              @default(false) @map("is_flagged_admin")
  flagReason            String?              @map("flag_reason")

  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer              Customer             @relation(fields: [customerId], references: [id])
  vendor                Vendor               @relation(fields: [vendorId], references: [id])
  rider                 Rider?               @relation(fields: [riderId], references: [id])

  items                 OrderItem[]
  statusHistory         OrderStatusHistory[]
  tracking              OrderTracking[]
  feedback              Feedback?
  supportRequests       SupportRequest[]
  analyticsEvents       AnalyticsEvent[]
  
  // Vendor-side specific relations (kept for backend compatibility)
  pickupRequests        PickupRequest[]
  deliveryStatusUpdates DeliveryStatusUpdate[]
  vendorOrderActions    VendorOrderAction[]
  vendorEarning         VendorEarning?
  riderEarning          RiderEarning?
  complianceFlags       VendorComplianceFlag[]

  @@map("orders")
  @@schema("customer")
}

// ─── VENDOR/RIDER SPECIFIC MODELS (vendor_delivery schema) ───────────────────

model Profile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid   String    @unique @map("firebase_uid")
  phoneNumber   String    @unique @map("phone_number")
  role          String?   @db.VarChar(20) // 'VENDOR', 'RIDER', 'CUSTOMER'
  profileStatus String    @default("PENDING") @map("profile_status") @db.VarChar(30)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  vendor    Vendor?
  rider     Rider?
  customer  Customer?

  @@map("profiles")
  @@schema("vendor_delivery")
}

model Vendor {
  id                 String    @id @default(uuid()) @db.Uuid
  profileId          String?   @unique @map("profile_id") @db.Uuid
  businessName       String    @map("business_name") @db.VarChar(255)
  ownerName          String    @map("owner_name") @db.VarChar(255)
  phone              String    @unique @db.VarChar(20)
  email              String?   @unique @db.VarChar(255)
  businessAddress    String    @map("business_address")
  latitude           Decimal?  @db.Decimal(10, 7)
  longitude          Decimal?  @db.Decimal(10, 7)
  deliveryRadius     Decimal?  @map("delivery_radius") @db.Decimal(6, 2)
  storeDescription   String?   @map("store_description")
  businessCategory   String?   @map("business_category") @db.VarChar(100)
  logoUrl            String?   @map("logo_url")
  bannerUrl          String?   @map("banner_url")
  profilePicUrl      String?   @map("profile_pic_url")
  operatingHours     Json?     @map("operating_hours")
  accountStatus      String    @default("kyc_submitted") @map("account_status") @db.VarChar(50)
  onlineStatus       String?   @default("offline") @map("online_status") @db.VarChar(30)
  stopNewOrdersSince DateTime? @map("stop_new_orders_since") @db.Timestamptz()
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  kycDocs            VendorKyc[]
  bankDetails        VendorBankDetails?
  complianceFlags    VendorComplianceFlag[]
  products           Product[]
  orders             Order[]
  orderActions       VendorOrderAction[]
  earnings           VendorEarning[]
  productSubmissions ProductReviewSubmission[]

  profile   Profile? @relation(fields: [profileId], references: [id])

  @@map("vendors")
  @@schema("vendor_delivery")
}

model Rider {
  id                 String    @id @default(uuid()) @db.Uuid
  profileId          String?   @unique @map("profile_id") @db.Uuid
  fullName           String    @map("full_name") @db.VarChar(255)
  phone              String    @unique @db.VarChar(20)
  email              String?   @unique @db.VarChar(255)
  profilePicUrl      String?   @map("profile_pic_url")
  vehicleType        String?   @map("vehicle_type") @db.VarChar(50)
  vehicleNumber      String?   @map("vehicle_number") @db.VarChar(50)
  preferredZone      String?   @map("preferred_zone")
  currentLat         Decimal?  @map("current_lat") @db.Decimal(10, 7)
  currentLng         Decimal?  @map("current_lng") @db.Decimal(10, 7)
  accountStatus      String    @default("kyc_submitted") @map("account_status") @db.VarChar(50)
  onlineStatus       String?   @default("offline") @map("online_status") @db.VarChar(30)
  stopNewOrdersSince DateTime? @map("stop_new_orders_since") @db.Timestamptz()
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime? @default(now()) @map("updated_at") @db.Timestamptz()

  kycDocs               RiderKyc[]
  bankDetails           RiderBankDetails?
  complianceFlags       RiderComplianceFlag[]
  orders                Order[]
  pickupRequests        PickupRequest[]
  deliveryStatusUpdates DeliveryStatusUpdate[]
  earnings              RiderEarning[]

  profile   Profile? @relation(fields: [profileId], references: [id])

  @@map("riders")
  @@schema("vendor_delivery")
}

// ─── ADDITIONAL CUSTOMER APP SUPPORT MODELS ─────────────────────────────────

model AgeVerification {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId     String    @unique @map("customer_id") @db.Uuid
  isVerified     Boolean   @default(false) @map("is_verified")
  verifiedAt     DateTime? @map("verified_at") @db.Timestamptz(6)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  birthDate      DateTime? @map("birth_date") @db.Date
  idType         String?   @map("id_type") @db.VarChar(100)
  verificationId String?   @map("verification_id")
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@map("age_verifications")
  @@schema("customer")
}

model Cart {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId  String?     @unique @map("customer_id") @db.Uuid
  guestId     String?     @unique @map("guest_id") @db.VarChar(255)
  vendorId    String      @map("vendor_id") @db.Uuid
  isGuest     Boolean     @default(false) @map("is_guest")
  expiresAt   DateTime?   @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items       CartItem[]
  @@map("carts")
  @@schema("customer")
}

model CartItem {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId                String           @map("cart_id") @db.Uuid
  productId             String           @map("product_id") @db.Uuid
  quantity              Int              @default(1)
  options               Json?
  ageVerifiedCheckbox   Boolean          @default(false) @map("age_verified_checkbox")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  cart                  Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  @@map("cart_items")
  @@schema("customer")
}

model OrderItem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @map("order_id") @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  productName     String    @map("product_name")
  quantity        Int
  unitPrice       Decimal   @map("unit_price") @db.Decimal(10, 2)
  addonsSummary   Json?     @map("addons_summary")
  lineTotal       Decimal   @map("line_total") @db.Decimal(10, 2)
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("order_items")
  @@schema("customer")
}

model OrderStatusHistory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  status      String    @db.VarChar(50)
  changedAt   DateTime  @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy   String?   @map("changed_by") @db.VarChar(50)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("order_status_history")
  @@schema("customer")
}

model OrderTracking {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String    @map("order_id") @db.Uuid
  latitude     Decimal   @db.Decimal(10, 7)
  longitude    Decimal   @db.Decimal(10, 7)
  recordedAt   DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("order_tracking")
  @@schema("customer")
}

model Feedback {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String    @unique @map("order_id") @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  rating        Int       @db.SmallInt
  comment       String?   @db.VarChar(150)
  submittedAt   DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer      Customer  @relation(fields: [customerId], references: [id])
  @@map("feedback")
  @@schema("customer")
}

model SupportRequest {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId   String?   @map("customer_id") @db.Uuid
  orderId      String?   @map("order_id") @db.Uuid
  optionLabel  String?   @map("option_label")
  isEscalated  Boolean   @default(false) @map("is_escalated")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  customer     Customer? @relation(fields: [customerId], references: [id])
  order        Order?    @relation(fields: [orderId], references: [id])
  @@map("support_requests")
  @@schema("customer")
}

model AnalyticsEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event       String    @map("event_name") @db.VarChar(100)
  orderId     String?   @map("order_id") @db.Uuid
  customerId  String?   @map("customer_id") @db.Uuid
  firedAt     DateTime  @default(now()) @map("fired_at") @db.Timestamptz(6)
  metadata    Json?
  order       Order?    @relation(fields: [orderId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  @@map("analytics_events")
  @@schema("customer")
}

// ─── VENDOR DELIVERY UTILITY MODELS ─────────────────────────────────────────

model VendorKyc {
  id                String    @id @default(uuid()) @db.Uuid
  vendorId          String    @map("vendor_id") @db.Uuid
  govIdType         String?   @map("gov_id_type") @db.VarChar(50)
  govIdUrl          String?   @map("gov_id_url")
  businessProofType String?   @map("business_proof_type") @db.VarChar(50)
  businessProofUrl  String?   @map("business_proof_url")
  panUrl            String?   @map("pan_url")
  addressProofUrl   String?   @map("address_proof_url")
  submissionRound   Int       @default(1) @map("submission_round")
  submittedAt       DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  @@map("vendor_kyc")
  @@schema("vendor_delivery")
}

model VendorBankDetails {
  id            String    @id @default(uuid()) @db.Uuid
  vendorId      String    @unique @map("vendor_id") @db.Uuid
  accountHolder String    @map("account_holder") @db.VarChar(255)
  bankName      String    @map("bank_name") @db.VarChar(255)
  accountNumber String    @map("account_number") @db.VarChar(50)
  ifscCode      String    @map("ifsc_code") @db.VarChar(20)
  upiId         String?   @map("upi_id") @db.VarChar(100)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  @@map("vendor_bank_details")
  @@schema("vendor_delivery")
}

model VendorComplianceFlag {
  id        String    @id @default(uuid()) @db.Uuid
  vendorId  String    @map("vendor_id") @db.Uuid
  flagType  String    @map("flag_type") @db.VarChar(100)
  orderId   String?   @map("order_id") @db.Uuid
  flaggedAt DateTime? @default(now()) @map("flagged_at") @db.Timestamptz()
  notes     String?
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])
  @@map("vendor_compliance_flags")
  @@schema("vendor_delivery")
}

model Product {
  id           String    @id @default(uuid()) @db.Uuid
  vendorId     String    @map("vendor_id") @db.Uuid
  name         String    @db.VarChar(255)
  description  String?
  category     String?   @db.VarChar(100)
  productType  String?   @map("product_type") @db.VarChar(100)
  basePrice    Decimal   @map("base_price") @db.Decimal(10, 2)
  isRestricted Boolean?  @default(false) @map("is_restricted")
  isActive     Boolean?  @default(true) @map("is_active")
  reviewStatus String    @default("pending_review") @map("review_status") @db.VarChar(30)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  vendor      Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  addOns      ProductAddon[]
  submissions ProductReviewSubmission[]
  snapshots   ProductReviewSnapshot[]
  @@map("products")
  @@schema("vendor_delivery")
}

model ProductAddon {
  id        String    @id @default(uuid()) @db.Uuid
  productId String    @map("product_id") @db.Uuid
  name      String    @db.VarChar(255)
  price     Decimal   @default(0) @db.Decimal(10, 2)
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("product_addons")
  @@schema("vendor_delivery")
}

model VendorOrderAction {
  id              String    @id @default(uuid()) @db.Uuid
  orderId         String    @map("order_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  action          String    @db.VarChar(50)
  rejectionReason String?   @map("rejection_reason") @db.VarChar(100)
  rejectionNote   String?   @map("rejection_note")
  newStatus       String?   @map("new_status") @db.VarChar(50)
  actionedAt      DateTime? @default(now()) @map("actioned_at") @db.Timestamptz()
  vendor Vendor @relation(fields: [vendorId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
  @@map("vendor_order_actions")
  @@schema("vendor_delivery")
}

model VendorEarning {
  id             String    @id @default(uuid()) @db.Uuid
  vendorId       String    @map("vendor_id") @db.Uuid
  orderId        String    @unique @map("order_id") @db.Uuid
  orderTotal     Decimal   @map("order_total") @db.Decimal(10, 2)
  commissionRate Decimal   @map("commission_rate") @db.Decimal(5, 2)
  commissionAmt  Decimal   @map("commission_amt") @db.Decimal(10, 2)
  vendorPayout   Decimal   @map("vendor_payout") @db.Decimal(10, 2)
  earnedAt       DateTime? @default(now()) @map("earned_at") @db.Timestamptz()
  vendor Vendor @relation(fields: [vendorId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
  @@map("vendor_earnings")
  @@schema("vendor_delivery")
}

model RiderKyc {
  id                String    @id @default(uuid()) @db.Uuid
  riderId           String    @map("rider_id") @db.Uuid
  govIdType         String?   @map("gov_id_type") @db.VarChar(50)
  govIdUrl          String?   @map("gov_id_url")
  drivingLicenseUrl String?   @map("driving_license_url")
  vehicleRegUrl     String?   @map("vehicle_reg_url")
  submissionRound   Int       @default(1) @map("submission_round")
  submittedAt       DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()
  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  @@map("rider_kyc")
  @@schema("vendor_delivery")
}

model RiderBankDetails {
  id            String    @id @default(uuid()) @db.Uuid
  riderId       String    @unique @map("rider_id") @db.Uuid
  accountHolder String    @map("account_holder") @db.VarChar(255)
  bankName      String    @map("bank_name") @db.VarChar(255)
  accountNumber String    @map("account_number") @db.VarChar(50)
  ifscCode      String    @map("ifsc_code") @db.VarChar(20)
  upiId         String?   @map("upi_id") @db.VarChar(100)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  @@map("rider_bank_details")
  @@schema("vendor_delivery")
}

model RiderComplianceFlag {
  id        String    @id @default(uuid()) @db.Uuid
  riderId   String    @map("rider_id") @db.Uuid
  flagType  String    @map("flag_type") @db.VarChar(100)
  orderId   String?   @map("order_id") @db.Uuid
  flaggedAt DateTime? @default(now()) @map("flagged_at") @db.Timestamptz()
  notes     String?
  rider Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  @@map("rider_compliance_flags")
  @@schema("vendor_delivery")
}

model PickupRequest {
  id          String    @id @default(uuid()) @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  riderId     String    @map("rider_id") @db.Uuid
  status      String    @default("broadcast") @db.VarChar(30)
  respondedAt DateTime? @map("responded_at") @db.Timestamptz()
  assignedAt  DateTime? @default(now()) @map("assigned_at") @db.Timestamptz()
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rider Rider @relation(fields: [riderId], references: [id])
  @@map("pickup_requests")
  @@schema("vendor_delivery")
}

model DeliveryStatusUpdate {
  id        String    @id @default(uuid()) @db.Uuid
  orderId   String    @map("order_id") @db.Uuid
  riderId   String    @map("rider_id") @db.Uuid
  status    String    @db.VarChar(50)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rider Rider @relation(fields: [riderId], references: [id])
  @@map("delivery_status_updates")
  @@schema("vendor_delivery")
}

model RiderEarning {
  id          String    @id @default(uuid()) @db.Uuid
  riderId     String    @map("rider_id") @db.Uuid
  orderId     String    @unique @map("order_id") @db.Uuid
  fixedFee    Decimal   @map("fixed_fee") @db.Decimal(10, 2)
  distanceFee Decimal   @default(0) @map("distance_fee") @db.Decimal(10, 2)
  totalPayout Decimal   @map("total_payout") @db.Decimal(10, 2)
  earnedAt    DateTime? @default(now()) @map("earned_at") @db.Timestamptz()
  rider Rider @relation(fields: [riderId], references: [id])
  order Order @relation(fields: [orderId], references: [id])
  @@map("rider_earnings")
  @@schema("vendor_delivery")
}

model ProductReviewSubmission {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  submissionRound Int       @default(1) @map("submission_round")
  status          String    @default("pending_review") @db.VarChar(30)
  submittedAt     DateTime? @default(now()) @map("submitted_at") @db.Timestamptz()
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor    Vendor                  @relation(fields: [vendorId], references: [id])
  snapshots ProductReviewSnapshot[]
  @@map("product_review_submissions")
  @@schema("vendor_delivery")
}

model ProductReviewSnapshot {
  id            String    @id @default(uuid()) @db.Uuid
  submissionId  String    @map("submission_id") @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  name          String    @db.VarChar(255)
  description   String?
  category      String?   @db.VarChar(100)
  productType   String?   @map("product_type") @db.VarChar(100)
  basePrice     Decimal   @map("base_price") @db.Decimal(10, 2)
  isRestricted  Boolean?  @default(false) @map("is_restricted")
  snapshotData  Json?     @map("snapshot_data")
  snapshottedAt DateTime? @default(now()) @map("snapshotted_at") @db.Timestamptz()
  submission ProductReviewSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  product    Product                 @relation(fields: [productId], references: [id])
  @@map("product_review_snapshots")
  @@schema("vendor_delivery")
}

model GuestSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guestId   String   @unique @map("guest_id") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("guest_sessions")
  @@schema("customer")
}
